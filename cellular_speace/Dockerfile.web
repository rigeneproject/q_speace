# T121 — SPEACE Secure Web Gateway
# Build: docker build -f Dockerfile.web -t speace-web .
# Run:   docker run -p 8000:8000 -v $(pwd)/data:/app/data speace-web

FROM python:3.12-slim

WORKDIR /app

# Install dependencies
COPY pyproject.toml README.md ./
RUN pip install --no-cache-dir -e ".[monitoring]"

# Copy source
COPY speace_core/ ./speace_core/
COPY scripts/ ./scripts/
COPY data/ ./data/

# Expose gateway port
EXPOSE 8000

# Run the secure web gateway
CMD ["python", "-m", "uvicorn", "speace_core.web_gateway.gateway_api:app", "--host", "0.0.0.0", "--port", "8000"]
