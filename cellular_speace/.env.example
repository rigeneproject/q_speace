# Ollama Cloud API key (premium models: glm-5.1, deepseek-v4-pro, Kimi-K2.7-Code, ...)
# Get yours at: https://ollama.com/settings/keys
OLLAMA_CLOUD_KEY=7310e98b57c04c65ad300627292d0d44.9nO4lREeOHUYivsVkPtZd8le

# SPEACE Anemos (chat interface) configuration
# Porta per l'interfaccia web Anemos (default 8788 per evitare conflitto con monitor su 8787)
ANEMOS_PORT=8788
# Endpoint LLM OpenAI-compatible. Esempi:
#   Ollama Cloud: https://api.ollama.cloud/v1/chat/completions
#   Ollama locale: http://localhost:11434/v1/chat/completions
ANEMOS_DEFAULT_API_URL=https://api.ollama.cloud/v1/chat/completions
# Modello LLM su Ollama Cloud (es. kimi-k2.7-code, glm-5.1, deepseek-v4-pro)
LLM_MODEL=kimi-k2.7-code

# Optional overrides (defaults shown)
# OLLAMA_CLOUD_ENDPOINT=https://api.ollama.cloud/v1
# OLLAMA_HOST=localhost
# OLLAMA_PORT=11434
